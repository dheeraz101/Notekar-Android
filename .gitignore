# ----------------------------------------------------------------------
# NoteKar Android (Flutter) Comprehensive .gitignore
# Ensures ZERO sensitive signing keys, passwords, or local paths
# are ever committed to GitHub.
# ----------------------------------------------------------------------

# 🔑 Android Signing Secrets & Passwords (CRITICAL - NEVER COMMIT)
**/key.properties
**/key.properties.*
**/local.properties
**/*.jks
**/*.keystore
**/*.pem
**/*.p12
**/*.pkcs12
**/*.crt
**/*.cer
**/*.der
**/*.key
**/*.asc
**/*.bks
**/*.pfx
**/upload-keystore.jks
**/debug.keystore
**/release-key.jks

# 🔐 API Secrets, Cloud Configs & Environment Files
**/.env
**/.env.*
!.env.example
**/*.env
**/secrets.json
**/credentials.json
**/service-account*.json
**/client_secret*.json
**/google-services.json
**/GoogleService-Info.plist
**/firebase_options.dart

# 🛠️ Build Artifacts, Cache & Generated Code
**/build/
**/coverage/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/.gradle/
**/.kotlin/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/ios/Pods/
**/ios/.symlinks/

# 📱 Compiled APKs, App Bundles & Releases
**/release/
**/output/
**/releases/
**/versions/
**/*.apk
**/*.aab
**/*.idsig
**/*.sha1
**/*.sha256

# 💻 IDEs, Editors & Project Specs
**/.idea/
**/*.iml
**/*.ipr
**/*.iws
**/.vscode/
**/.atom/
**/.history
**/.svn/

# 📝 Personal Docs, Local Notes & Word Documents
**/*.docx
**/*.doc
**/*.log
**/*.tmp
**/*.temp
**/*.bak
**/*.local
**/*.private

# 🖥️ Operating System Metadata
**/.DS_Store
**/.DS_Store?
**/._*
**/.Spotlight-V100
**/.Trashes
**/ehthumbs.db
**/Thumbs.db
**/desktop.ini
