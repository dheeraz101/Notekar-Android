<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:background="@drawable/notekar_widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NoteKar"
            android:textColor="#FFFFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 today"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            android:maxLines="1" />

    </LinearLayout>

    <TextView
        android:id="@+id/widget_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Next: IN"
        android:textColor="#FF64D2FF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="1" />

    <TextView
        android:id="@+id/widget_last"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="No moments yet"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_single"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:gravity="center"
            android:text="Single"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/notekar_widget_button" />

        <TextView
            android:id="@+id/widget_in"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="5dp"
            android:gravity="center"
            android:text="IN"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/notekar_widget_button" />

        <TextView
            android:id="@+id/widget_out"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="5dp"
            android:gravity="center"
            android:text="OUT"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/notekar_widget_button" />

        <TextView
            android:id="@+id/widget_note"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:gravity="center"
            android:text="Note"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/notekar_widget_button" />

    </LinearLayout>

    <TextView
        android:id="@+id/widget_history"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Open History"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/notekar_widget_button"
        android:visibility="gone" />

</LinearLayout>